# Entorno y debug
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# API
API_V1_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Base de datos (usa SQLite para desarrollo rapido sin Docker, o Postgres con docker compose)
DATABASE_URL=postgresql+psycopg://crowgest:crowgest@localhost:5432/crowgest
DATABASE_ECHO=false

# Auth: en desarrollo se puede deshabilitar para no precisar credenciales de Firebase
AUTH_DISABLED=true
FIREBASE_PROJECT_ID=
# Path al JSON de service account o el JSON inline; dejar vacio si AUTH_DISABLED=true
FIREBASE_CREDENTIALS_JSON=

# AFIP / ARCA (backend)
AFIP_MODE=simulated
AFIP_CUIT=
AFIP_PUNTO_VENTA_DEFAULT=1
AFIP_CAE_DIAS_VALIDEZ=10
